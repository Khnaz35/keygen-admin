<%- include("partials/header") %>

<% const lmeta = license.attributes.metadata || {}; %>

<div class="page-card">
    <div class="card-head">
        <h2 class="font-mono"><%= license.attributes.key %></h2>
        <div class="flex items-center gap-3">
            <%- include("partials/status", { status: license.attributes.status }) %>
            <a href="/product/<%= license.relationships.product.data.id %>" class="link">Product</a>
        </div>
    </div>
    <div class="defrow"><div class="k">License ID</div><div class="v font-mono text-xs"><%= license.id %></div></div>
    <div class="defrow"><div class="k">Key</div><div class="v font-mono text-xs"><%= license.attributes.key %></div></div>
    <div class="defrow"><div class="k">Email</div><div class="v"><%= lmeta.email || "—" %></div></div>
    <div class="defrow"><div class="k">Last validated</div><div class="v"><%= license.attributes.lastValidated ? license.attributes.lastValidated.split("T")[0] : "never" %></div></div>
    <div class="defrow">
        <div class="k">Expires</div>
        <div class="v">
            <% if (license.attributes.expiry) { %>
            <%= license.attributes.expiry.split("T")[0] %><% if (typeof days !== "undefined" && days !== null) { %> <span class="<%= days < 0 ? 'text-red-600' : 'muted' %>">(<%= days %> days<%= days < 0 ? " ago" : " left" %>)</span><% } %>
            <% } else { %>
            <span class="muted">perpetual</span>
            <% } %>
        </div>
    </div>
    <div class="defrow"><div class="k">Created</div><div class="v"><%= license.attributes.created.split("T")[0] %></div></div>
</div>

<% const machineList = (typeof machines !== "undefined" && machines) ? machines : []; %>
<div class="page-card">
    <div class="card-head">
        <h2>Activations &amp; store</h2>
    </div>
    <% for (const machine of machineList) { %>
    <% const meta = (machine.attributes && machine.attributes.metadata) ? machine.attributes.metadata : {}; %>
    <div class="defrow"><div class="k">Domain</div><div class="v font-medium"><%= machine.attributes.fingerprint || "—" %></div></div>
    <div class="defrow"><div class="k">Store</div><div class="v"><%= meta.store || "—" %></div></div>
    <div class="defrow"><div class="k">Owner</div><div class="v"><%= meta.owner || "—" %></div></div>
    <div class="defrow"><div class="k">Email</div><div class="v"><%= meta.email || "—" %></div></div>
    <div class="defrow"><div class="k">Telephone</div><div class="v"><%= meta.telephone || "—" %></div></div>
    <div class="defrow"><div class="k">Address</div><div class="v"><%= meta.address || "—" %></div></div>
    <div class="defrow"><div class="k">URL</div><div class="v"><%= meta.url || "—" %></div></div>
    <div class="defrow"><div class="k">Platform</div><div class="v"><%= meta.platform || "—" %></div></div>
    <div class="flex justify-end px-6 py-3">
        <a href="/machine/<%= machine.id %>/delete" class="text-sm font-medium text-red-600 hover:text-red-700" onClick="return confirm('Reset this activation so the merchant can re-activate on a new domain?')">Reset activation</a>
    </div>
    <% } %>
    <% if (machineList.length === 0) { %>
    <div class="defrow"><div class="v muted">No activation yet &mdash; the merchant has not entered and saved the key on their store.</div></div>
    <% } %>
</div>

<div class="flex justify-end">
    <a href="/license/<%= license.id %>/delete" class="text-sm font-medium text-red-600 hover:text-red-700" onClick="return confirm('Delete this license permanently?')">Delete license</a>
</div>

<%- include("partials/footer") %>
