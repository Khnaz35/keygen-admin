<%- include("partials/header") %>

<div class="page-card">
    <div class="card-head">
        <h2><%= product.attributes.name %></h2>
        <a href="/products" class="link">Back to products</a>
    </div>
    <div class="defrow"><div class="k">Product ID</div><div class="v font-mono text-xs"><%= product.id %></div></div>
    <div class="defrow"><div class="k">Account ID</div><div class="v font-mono text-xs"><%= process.env.KEYGEN_ACCOUNT_ID %></div></div>
    <div class="defrow"><div class="k">Created</div><div class="v"><%= product.attributes.created.split("T")[0] %></div></div>
</div>

<div class="page-card">
    <div class="card-head">
        <h2>Policies</h2>
        <a href="/product/<%= product.id %>/policies/create" class="btn">Add policy</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Name</th><th>Options</th><th>Created</th></tr>
            </thead>
            <tbody>
                <% for (const policy of policies) { %>
                <tr>
                    <td><a class="link" href="/policy/<%= policy.id %>"><%= policy.attributes.name %></a></td>
                    <td class="text-xs text-gray-500">
                        duration=<%= policy.attributes.duration || "-1" %> &middot;
                        max machines=<%= policy.attributes.maxMachines || "-1" %> &middot;
                        floating=<%= policy.attributes.floating %> &middot;
                        uniqueness=<%= policy.attributes.machineUniquenessStrategy %>
                    </td>
                    <td class="muted"><%= policy.attributes.created.split("T")[0] %></td>
                </tr>
                <% } %>
                <% if (policies.length === 0) { %>
                <tr><td colspan="3" class="muted">No policies found</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div class="page-card">
    <div class="card-head">
        <h2>Licenses</h2>
        <a href="/product/<%= product.id %>/licenses/create" class="btn btn-primary">Add license</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Store</th>
                    <th>Email</th>
                    <th>Domain</th>
                    <th>Key</th>
                    <th>Status</th>
                    <th>Expires</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                <% for (const license of licenses) { %>
                <% const meta = license.attributes.metadata || {}; %>
                <tr>
                    <td><a class="link" href="/license/<%= license.id %>"><%= license.merchant.store || meta.store || "—" %></a></td>
                    <td><%= meta.email || license.merchant.email || "—" %></td>
                    <td class="mono"><%= license.merchant.domain || "—" %></td>
                    <td class="mono"><%= license.attributes.key.split("-")[0] %></td>
                    <td><%- include("partials/status", { status: license.attributes.status }) %></td>
                    <td>
                        <% if (license.attributes.expiry) { %>
                        <%= license.attributes.expiry.split("T")[0] %><% if (license.days !== null) { %> <span class="<%= license.days < 0 ? 'text-red-600' : 'muted' %>">(<%= license.days %>d)</span><% } %>
                        <% } else { %>
                        <span class="muted">perpetual</span>
                        <% } %>
                    </td>
                    <td class="muted"><%= license.attributes.created.split("T")[0] %></td>
                </tr>
                <% } %>
                <% if (licenses.length === 0) { %>
                <tr><td colspan="7" class="muted">No licenses found</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include("partials/footer") %>
