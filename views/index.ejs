<%- include("partials/header") %>

<div class="stats">
    <div class="stat">
        <div class="num"><%= stats.licenses %></div>
        <div class="label">Licenses</div>
    </div>
    <div class="stat">
        <div class="num text-green-600"><%= stats.active %></div>
        <div class="label">Active</div>
    </div>
    <div class="stat">
        <div class="num <%= stats.expiring ? 'text-amber-600' : '' %>"><%= stats.expiring %></div>
        <div class="label">Expiring &le; 30 days</div>
    </div>
    <div class="stat">
        <div class="num"><%= stats.products %></div>
        <div class="label">Products</div>
    </div>
</div>

<div class="page-card">
    <div class="card-head">
        <h2>Recent licenses</h2>
        <a href="/licenses" class="link">View all</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Store</th>
                    <th>Domain</th>
                    <th>Product</th>
                    <th>Status</th>
                    <th>Expires</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                <% for (const row of recent) { %>
                <tr>
                    <td><a class="link" href="/license/<%= row.id %>"><%= row.merchant.store || "—" %></a></td>
                    <td class="mono"><%= row.merchant.domain || "—" %></td>
                    <td><%= row.product %></td>
                    <td><%- include("partials/status", { status: row.status }) %></td>
                    <td>
                        <% if (row.expiry) { %>
                        <%= row.expiry.split("T")[0] %><% if (row.days !== null) { %> <span class="<%= row.days < 0 ? 'text-red-600' : 'muted' %>">(<%= row.days %>d)</span><% } %>
                        <% } else { %>
                        <span class="muted">perpetual</span>
                        <% } %>
                    </td>
                    <td class="muted"><%= row.created.split("T")[0] %></td>
                </tr>
                <% } %>
                <% if (recent.length === 0) { %>
                <tr><td colspan="6" class="muted">No licenses yet.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div class="page-card">
    <div class="card-head">
        <h2>Products</h2>
        <a href="/products" class="link">Manage</a>
    </div>
    <div class="cards">
        <% for (const product of products) { %>
        <a class="card" href="/product/<%= product.id %>">
            <div class="text-base font-semibold text-gray-900"><%= product.attributes.name %></div>
            <div class="mt-3 flex gap-6">
                <div>
                    <div class="text-2xl font-semibold text-gray-900"><%= product.total %></div>
                    <div class="text-xs uppercase tracking-wide text-gray-500">Licenses</div>
                </div>
                <div>
                    <div class="text-2xl font-semibold text-green-600"><%= product.active %></div>
                    <div class="text-xs uppercase tracking-wide text-gray-500">Active</div>
                </div>
            </div>
        </a>
        <% } %>
    </div>
</div>

<%- include("partials/footer") %>
