<%- include("partials/header") %>
<div class="pt-8 bg-gray-100 rounded-xl text-gray-800">
    <div id="breadcrumbs" class="-mt-2 flex gap-1 items-center text-xs px-8">
        <a class="text-gray-700 font-medium" href="/">Keygen Admin</a>
    </div>

    <h1 class="text-3xl my-4 px-8 flex gap-1 items-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>

        Keygen Admin
    </h1>


    <div class="flex flex-col bg-gray-50 border-t border-t-gray-200 rounded-b-xl">
        <div class="cards">
            <% for (const product of products) { %>
            <a class="card" href="/product/<%= product.id %>">
                <div class="text-lg font-medium text-gray-800"><%= product.attributes.name %></div>
                <div class="mt-3 flex gap-6">
                    <div>
                        <div class="text-2xl font-semibold text-gray-900"><%= product.total %></div>
                        <div class="text-xs uppercase tracking-wide text-gray-500">Licenses</div>
                    </div>
                    <div>
                        <div class="text-2xl font-semibold text-green-600"><%= product.active %></div>
                        <div class="text-xs uppercase tracking-wide text-gray-500">Active</div>
                    </div>
                </div>
            </a>
            <% } %>
            <% if (products.length === 0) { %>
            <div class="text-gray-500">No products yet. <a href="/products/create">Add one</a>.</div>
            <% } %>
        </div>
        <div class="px-8 pb-6 -mt-2">
            <a href="/products" class="text-sm text-gray-600">Manage all products</a>
        </div>
    </div>
</div>
<%- include("partials/footer") %>