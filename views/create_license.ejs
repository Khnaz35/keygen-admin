<%- include("partials/header") %>

<div class="page-card">
    <div class="card-head">
        <h2>Create license &mdash; <%= product.attributes.name %></h2>
        <a href="/product/<%= product.id %>" class="link">Back to product</a>
    </div>
    <form method="POST" action="/product/<%= product.id %>/licenses/create" class="form">
        <% if (typeof error !== "undefined") { %>
        <div class="err"><%= error %></div>
        <% } %>
        <label>
            Policy
            <select name="policy_id">
                <% policies.forEach(function(policy) { %>
                <option value="<%= policy.id %>"><%= policy.attributes.name %></option>
                <% }) %>
            </select>
        </label>
        <label>
            Email
            <input type="email" name="email" required />
        </label>
        <div>
            <button type="submit" class="btn btn-primary">Create license</button>
        </div>
    </form>
</div>

<%- include("partials/footer") %>
