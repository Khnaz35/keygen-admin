<%- include("partials/header") %>

<div class="page-card">
    <div class="card-head">
        <h2>Create policy &mdash; <%= product.attributes.name %></h2>
        <a href="/product/<%= product.id %>" class="link">Back to product</a>
    </div>
    <form method="POST" action="/product/<%= product.id %>/policies/create" class="form">
        <% if (typeof error !== "undefined") { %>
        <div class="err"><%= error %></div>
        <% } %>
        <label>
            Attributes (JSON)
            <textarea name="data" class="h-64 font-mono" required><%= typeof data !== "undefined" ? data : `{
    "name": "Paid Policy",
    "duration": null,
    "maxMachines": 5,
    "floating": true,
    "machineUniquenessStrategy": "UNIQUE_PER_POLICY"
}` %></textarea>
        </label>
        <p class="hint">See the <a class="link" href="https://keygen.sh/docs/api/policies/#policies-create-attrs" target="_blank">API reference</a> for available policy attributes.</p>
        <div>
            <button type="submit" class="btn btn-primary">Add policy</button>
        </div>
    </form>
</div>

<%- include("partials/footer") %>
