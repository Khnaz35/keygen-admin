<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <title><%= brandName %> &mdash; Sign in</title>
    <link rel="stylesheet" href="/app.css">
</head>

<body class="login-body">
    <div class="login-card">
        <div class="login-brand">
            <% if (brandLogo) { %>
            <img src="<%= brandLogo %>" alt="<%= brandName %>" class="login-logo" />
            <% } else { %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-gray-800"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" /></svg>
            <% } %>
            <div class="login-title"><%= brandName %></div>
        </div>

        <% if (error) { %>
        <div class="login-error">
            <% if (error === "denied") { %>This Google account is not allowed to access this dashboard.
            <% } else if (error === "state") { %>Your sign-in session expired. Please try again.
            <% } else { %>Sign-in failed. Please try again.<% } %>
        </div>
        <% } %>

        <% if (googleEnabled) { %>
        <a href="/auth/google" class="google-btn">
            <svg viewBox="0 0 48 48" class="h-5 w-5"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            <span>Sign in with Google</span>
        </a>
        <% } else { %>
        <div class="login-error">Google sign-in is not configured. Set the OAuth environment variables.</div>
        <% } %>
    </div>
</body>

</html>
