<%- include("partials/header") %>

<div class="page-card">
    <div class="card-head">
        <h2>Products</h2>
        <a href="/products/create" class="btn btn-primary">Add product</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Licenses</th>
                    <th>Active</th>
                    <th>ID</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                <% for (const product of products) { %>
                <tr>
                    <td><a class="link" href="/product/<%= product.id %>"><%= product.attributes.name %></a></td>
                    <td><%= typeof product.total !== "undefined" ? product.total : "—" %></td>
                    <td class="text-green-600"><%= typeof product.active !== "undefined" ? product.active : "—" %></td>
                    <td class="mono"><%= product.id.split("-")[0] %></td>
                    <td class="muted"><%= product.attributes.created.split("T")[0] %></td>
                </tr>
                <% } %>
                <% if (products.length === 0) { %>
                <tr><td colspan="5" class="muted">No products found</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include("partials/footer") %>
